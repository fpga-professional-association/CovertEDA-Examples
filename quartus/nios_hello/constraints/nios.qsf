set_location_assignment PIN_M22 -to seg_output[5]
set_location_assignment PIN_M21 -to seg_output[6]
set_location_assignment PIN_M20 -to seg_output[7]

set_location_assignment PIN_Y23 -to gpio_bidir[0]
set_location_assignment PIN_Y24 -to gpio_bidir[1]
