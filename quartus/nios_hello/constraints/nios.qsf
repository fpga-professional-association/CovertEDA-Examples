set_location_assignment PIN_C8 -to led_output[5]
set_location_assignment PIN_B8 -to led_output[6]
set_location_assignment PIN_A8 -to led_output[7]

set_location_assignment PIN_P20 -to seg_output[0]
set_location_assignment PIN_P19 -to seg_output[1]
set_location_assignment PIN_N20 -to seg_output[2]
set_location_assignment PIN_N19 -to seg_output[3]
