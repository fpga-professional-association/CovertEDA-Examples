# Design Files
set_global_assignment -name VERILOG_FILE src/nios_top.v
set_global_assignment -name VERILOG_FILE src/system_pll.v
set_global_assignment -name VERILOG_FILE src/gpio_ctrl.v
set_global_assignment -name QIP_FILE system/system.qip

# Pin Assignments
set_location_assignment PIN_E1 -to clk_100m
set_location_assignment PIN_J15 -to rst_n
set_location_assignment PIN_E21 -to sw_input[0]
set_location_assignment PIN_E22 -to sw_input[1]
