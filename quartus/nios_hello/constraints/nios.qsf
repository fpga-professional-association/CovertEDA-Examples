set_location_assignment PIN_AA19 -to gpio_bidir[6]
set_location_assignment PIN_AB19 -to gpio_bidir[7]

# I/O Attributes
set_instance_assignment -name IO_STANDARD "3.3-V LVCMOS" -to clk_100m
set_instance_assignment -name IO_STANDARD "3.3-V LVCMOS" -to rst_n
set_instance_assignment -name IO_STANDARD "3.3-V LVCMOS" -to sw_input[*]
set_instance_assignment -name IO_STANDARD "3.3-V LVCMOS" -to led_output[*]
set_instance_assignment -name IO_STANDARD "3.3-V LVCMOS" -to seg_output[*]
set_instance_assignment -name IO_STANDARD "3.3-V LVCMOS" -to gpio_bidir[*]

set_instance_assignment -name SLEW_RATE 1 -to led_output
set_instance_assignment -name SLEW_RATE 1 -to seg_output
set_instance_assignment -name CURRENT_STRENGTH_NEW "12MA" -to led_output
set_instance_assignment -name CURRENT_STRENGTH_NEW "12MA" -to seg_output
set_instance_assignment -name WEAK_PULL_UP_RESISTOR ON -to rst_n

# Timing
set_global_assignment -name SDC_FILE constraints/nios.sdc

# Device & Compiler Settings
set_global_assignment -name DEVICE_FILTER_SPEED_GRADE 7
set_global_assignment -name CYCLONE_OPTIMIZATION_TECHNIQUE SPEED
set_global_assignment -name POWER_PRESET_COOLING_SOLUTION "NO HEAT SINK WITH SOME AIR CIRCULATION"
