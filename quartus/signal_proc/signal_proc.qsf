# I/O Attributes
set_instance_assignment -name IO_STANDARD "LVCMOS 1.5V" -to clk_200m
set_instance_assignment -name IO_STANDARD "LVCMOS 1.5V" -to rst_n
set_instance_assignment -name IO_STANDARD "LVCMOS 1.5V" -to adc_data[*]
set_instance_assignment -name IO_STANDARD "LVCMOS 1.5V" -to adc_valid
set_instance_assignment -name IO_STANDARD "LVCMOS 1.5V" -to nco_freq[*]
set_instance_assignment -name IO_STANDARD "LVCMOS 1.5V" -to decim_rate[*]
set_instance_assignment -name IO_STANDARD "LVCMOS 1.5V" -to i_data[*]
set_instance_assignment -name IO_STANDARD "LVCMOS 1.5V" -to q_data[*]
set_instance_assignment -name IO_STANDARD "LVCMOS 1.5V" -to output_valid

set_instance_assignment -name SLEW_RATE 1 -to i_data
set_instance_assignment -name SLEW_RATE 1 -to q_data
set_instance_assignment -name CURRENT_STRENGTH_NEW "12MA" -to i_data
set_instance_assignment -name CURRENT_STRENGTH_NEW "12MA" -to q_data

# Timing
set_global_assignment -name SDC_FILE constraints/ddc.sdc

# Device & Compiler Settings
set_global_assignment -name POWER_PRESET_COOLING_SOLUTION "NO HEAT SINK WITH SOME AIR CIRCULATION"
set_global_assignment -name POWER_BOARD_THERMAL_MODEL "NONE (CONSERVATIVE)"
