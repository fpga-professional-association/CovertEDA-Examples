# Quartus Prime Pro QSF for Digital Downconverter (DDC)
# Updated for Cyclone 10 GX - 10CX085YU484E5G

set_global_assignment -name FAMILY "Cyclone 10 GX"
set_global_assignment -name DEVICE 10CX085YU484E5G
set_global_assignment -name TOP_LEVEL_ENTITY ddc_top
set_global_assignment -name ORIGINAL_QUARTUS_VERSION 11.0
set_global_assignment -name PROJECT_CREATION_TIME_DATE "11:45:30 MAR 21 2026"
set_global_assignment -name LAST_QUARTUS_VERSION 11.0
set_global_assignment -name PROJECT_OUTPUT_DIRECTORY output_files

set_global_assignment -name SMART_RECOMPILE ON
set_global_assignment -name NUM_PARALLEL_PROCESSORS 4
set_global_assignment -name SYNTH_TIMING_DRIVEN_SYNTHESIS ON
set_global_assignment -name FITTER_AGGRESSIVE_ROUTABILITY_OPTIMIZATION LEVEL_2

# Design Files
set_global_assignment -name VERILOG_FILE src/ddc_top.v
set_global_assignment -name VERILOG_FILE src/nco.v
set_global_assignment -name VERILOG_FILE src/cic_filter.v
set_global_assignment -name VERILOG_FILE src/fir_decimate.v

