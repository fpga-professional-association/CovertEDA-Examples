# Libero PDC constraints for ps2_keyboard
# Device: MPF100T-1FCG484I

set_io clk -pinname P19 -fixed yes
set_io reset_n -pinname R1 -fixed yes
set_io ps2_clk -pinname T2 -fixed yes
set_io ps2_data -pinname T3 -fixed yes

set_io clk -iostandard LVCMOS33
set_io reset_n -iostandard LVCMOS33
set_io ps2_clk -iostandard LVCMOS33
set_io ps2_data -iostandard LVCMOS33
