# CovertEDA-managed Libero SoC project script for ecc_memory
new_project -name "ecc_memory" -location "./libero_proj" \
            -hdl "VERILOG" -family "PolarFire" -die "MPF300T" \
            -package "FCG484" -speed "-1" -part_range "COM"
import_files -hdl_source {src/ecc_memory.v}
import_files -fp_pdc {constraints/ecc_memory.pdc}
set_root ecc_memory
save_project
close_project
