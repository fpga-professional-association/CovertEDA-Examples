# CovertEDA-managed Libero SoC project script for wishbone_arbiter
new_project -name "wishbone_arbiter" -location "./libero_proj" \
            -hdl "VERILOG" -family "PolarFire" -die "MPF300T" \
            -package "FCG484" -speed "-1" -part_range "COM"
import_files -hdl_source {src/wishbone_arbiter.v}
import_files -fp_pdc {constraints/wishbone_arbiter.pdc}
set_root wishbone_arbiter
save_project
close_project
