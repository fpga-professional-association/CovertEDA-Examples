# Libero Physical Design Constraints (PDC) for Blinky LED
# Device: MPF300T-1FCG484I
# Package: FCG484

# Clock input - 50 MHz
set_io clk

# Reset input (active low)
set_io rst_n

# LED output
set_io led

# Bank voltage constraints
set_io clk -bank 1 -iostandard LVCMOS33

# I/O standard definitions
set_io rst_n -iostandard LVCMOS33 -bank 1
set_io led -iostandard LVCMOS33 -bank 2 -slew SLOW -drive 8
