# CovertEDA-managed Libero SoC project script for rs232_bridge
new_project -name "rs232_bridge" -location "./libero_proj" \
            -hdl "VERILOG" -family "PolarFire" -die "MPF300T" \
            -package "FCG484" -speed "-1" -part_range "COM"
import_files -hdl_source {src/rs232_bridge.v}
import_files -fp_pdc {constraints/rs232_bridge.pdc}
set_root rs232_bridge
save_project
close_project
