# CovertEDA-managed Libero SoC project script for modbus_rtu
new_project -name "modbus_rtu" -location "./libero_proj" \
            -hdl "VERILOG" -family "PolarFire" -die "MPF300T" \
            -package "FCG484" -speed "-1" -part_range "COM"
import_files -hdl_source {src/modbus_rtu.v}
import_files -fp_pdc {constraints/modbus_rtu.pdc}
set_root modbus_rtu
save_project
close_project
