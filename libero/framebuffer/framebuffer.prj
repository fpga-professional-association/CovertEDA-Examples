# CovertEDA-managed Libero SoC project script for framebuffer
new_project -name "framebuffer" -location "./libero_proj" \
            -hdl "VERILOG" -family "PolarFire" -die "MPF300T" \
            -package "FCG484" -speed "-1" -part_range "COM"
import_files -hdl_source {src/framebuffer.v}
import_files -fp_pdc {constraints/framebuffer.pdc}
set_root framebuffer
save_project
close_project
