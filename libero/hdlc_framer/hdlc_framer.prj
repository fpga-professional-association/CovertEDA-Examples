# CovertEDA-managed Libero SoC project script for hdlc_framer
new_project -name "hdlc_framer" -location "./libero_proj" \
            -hdl "VERILOG" -family "PolarFire" -die "MPF300T" \
            -package "FCG484" -speed "-1" -part_range "COM"
import_files -hdl_source {src/hdlc_framer.v}
import_files -fp_pdc {constraints/hdlc_framer.pdc}
set_root hdlc_framer
save_project
close_project
